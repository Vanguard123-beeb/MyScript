--- 4. ระบบลูปการทำงาน (Back-end) ---

task.spawn(function()
    while true do
        task.wait(0.1)
        
        if _G.Purchasing and _G.SelectedRarity2 and next(_G.SelectedRarity2) ~= nil then

            for _, hero in pairs(workspace.HeroCenter:GetChildren()) do
                if not _G.Purchasing then break end

                local root = hero:FindFirstChild("HumanoidRootPart")
                if root then
                    local billboard = root:FindFirstChild("HeroBillboardCircle")
                    local prompt = root:FindFirstChild("HeroPurchasePrompt")

                    -- เช็ค Enabled ให้ชัดเจน
                    if billboard and prompt and prompt:IsA("ProximityPrompt") then
                        
                        -- ดึง Rarity
                        local rarityLabel = billboard:FindFirstChild("HeroRarity")
                        local isTargetRarity = rarityLabel and _G.SelectedRarity2[rarityLabel.Text]

                        -- เช็ค Enabled อีกรอบก่อนกด (Double Check)
                        if isTargetRarity and prompt.Enabled == true then
                            pcall(function()
                                if prompt.Enabled then 
                                    Player.Character.HumanoidRootPart.CFrame = CFrame.new(0, 3, 0)
                                    wait(2)
                                    fireproximityprompt(prompt)
                                end
                            end)
                            task.wait(0.2) -- เพิ่มหน่วงเวลานิดนึงเพื่อให้ Server ทัน Update สถานะ
                        end
                    end
                end
            end
        end
    end
end)


task.spawn(function()    
    while true do
        task.wait(2)
        if _G.Selling and _G.SelectedRarity and next(_G.SelectedRarity) ~= nil then
            local hasSelection = false
            for _, enabled in pairs(_G.SelectedRarity) do
                if enabled then hasSelection = true break end
            end

            if hasSelection then
                pcall(function()
                    Remotes:WaitForChild("SellBulk"):InvokeServer("Brainrot", _G.SelectedRarity)
                end)
            end
        end
    end
end)

-- ลูป Auto Collect (เก็บเงิน 1-11)
task.spawn(function()
    local collectRemote = Remotes:WaitForChild("CollectBrainrotIncome")
    while true do
        if _G.Collecting then
            for i = 1, 20 do
                if not _G.Collecting then break end
                task.spawn(function()
                    collectRemote:InvokeServer(tostring(i))
                end)
                task.wait(0.05)
            end
            task.wait(0.5)
        else
            task.wait(1)
        end
    end
end)

