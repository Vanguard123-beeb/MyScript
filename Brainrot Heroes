-- 0. ประกาศตัวแปร Global ไว้ก่อนเพื่อกัน Error ใน Loop
_G.SelectedRarity = {}
_G.SelectedHeroes = {}
_G.Collecting = false
_G.Selling = false

-- 1. เตรียมข้อมูลจาก Assets
local Heroes = {}
local Rarity = {}
local assetsFolder = ReplicatedStorage:WaitForChild("Assets")
local Gradients = assetsFolder:WaitForChild("Gradients")
local rarityGroup = Gradients:WaitForChild("Rarity")
local heroesFolder = assetsFolder:WaitForChild("Heroes")

-- รอให้ Object โหลดเข้ามาก่อน (ป้องกัน Dropdown ว่าง)
repeat task.wait(0.5) until #rarityGroup:GetChildren() > 0 and #heroesFolder:GetChildren() > 0

-- ดึงรายชื่อ Rarity (ตรวจสอบ ClassName ให้ตรงกับในเกมของคุณ)
for _, rarity in pairs(rarityGroup:GetChildren()) do
    if rarity:IsA("UIGradient") or rarity:IsA("UiGradient") then
        table.insert(Rarity, rarity.Name)
    end
end

-- ดึงรายชื่อ Heroes
for _, hero in pairs(heroesFolder:GetChildren()) do
    if hero:IsA("Model") then
        table.insert(Heroes, hero.Name)
    end
end

local NotificationsOn = true 

