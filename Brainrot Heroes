    Callback = function(value)
        _G.Selling = value
        -- เมื่อเปิด ให้ส่งลิสต์ปัจจุบันไปกระตุ้นระบบเกม
        if value and _G.SelectedRarity then
            pcall(function()
                Remotes:WaitForChild("SellBulk"):FireServer({_G.SelectedRarity})
            end)
        end
        SmartNotify({ Title = "Sell Status", Description = (value and "Enabled" or "Disabled") .. " Auto Sell", Lifetime = 3 })
